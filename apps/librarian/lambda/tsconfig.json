{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "aws-lambda"]
  },
  "include": ["auth/**/*", "chat/**/*", "dispatch/**/*", "eval/**/*", "shared/**/*"],
  "exclude": ["dist", "node_modules"]
}
