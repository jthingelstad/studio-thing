{
  "name": "weekly-thing-librarian",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "contract:generate": "node scripts/export-contract.mjs",
    "contract:sync-thingy": "node scripts/export-contract.mjs ../../../../thingy.thingelstad.com/web/contracts/librarian-api.v1.json",
    "format": "prettier --write \"{auth,chat,dispatch,eval,shared}/**/*.mts\" \"scripts/**/*.mjs\" \"*.json\"",
    "format:check": "prettier --check \"{auth,chat,dispatch,eval,shared}/**/*.mts\" \"scripts/**/*.mjs\" \"*.json\"",
    "lint": "oxlint . --deny-warnings",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "verify": "npm run contract:generate && npm run format:check && npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.1090.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1090.0",
    "@aws-sdk/client-dynamodb": "^3.1090.0",
    "@aws-sdk/client-s3": "^3.1090.0",
    "markdown-it": "^14.3.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.13.3",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  }
}
